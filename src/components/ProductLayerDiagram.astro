---
interface Props {
  locale?: "en" | "ja";
}

const { locale = "en" } = Astro.props;

const copy = {
  en: {
    title: "SnapVM product layer",
    users: "Developers",
    snapvmTitle: "SnapVM",
    snapvmItems: ["Console", "Authentication and authorization", "Plans and billing"],
    spritesTitle: "MicroVM (Sprites)",
    spritesItems: ["Persistent Linux workspaces", "Hibernation", "microVM isolation"],
    userToSnapvm: "Create and manage machines",
    snapvmToSprites: "Runs workspaces on Sprites",
  },
  ja: {
    title: "SnapVM のプロダクトレイヤー",
    users: "開発者",
    snapvmTitle: "SnapVM",
    snapvmItems: ["コンソール", "認証・認可", "料金プラン"],
    spritesTitle: "MicroVM (Sprites)",
    spritesItems: ["永続 Linux ワークスペース", "ハイバネーション", "microVM 隔離"],
    userToSnapvm: "マシンを作成・管理",
    snapvmToSprites: "Sprites 上でワークスペースを実行",
  },
}[locale];

const nodes = [
  { key: "users", x: 40, y: 100, width: 170, height: 78, title: copy.users, items: [] },
  {
    key: "snapvm",
    x: 320,
    y: 48,
    width: 230,
    height: 154,
    title: copy.snapvmTitle,
    items: copy.snapvmItems,
  },
  {
    key: "sprites",
    x: 660,
    y: 48,
    width: 230,
    height: 154,
    title: copy.spritesTitle,
    items: copy.spritesItems,
  },
];
---

<figure class="product-layer-diagram">
  <svg viewBox="0 0 930 250" role="img" aria-labelledby="product-layer-title">
    <title id="product-layer-title">{copy.title}</title>
    <defs>
      <marker
        id="product-arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto-start-reverse"
      >
        <path d="M0 0 L10 5 L0 10 Z"></path>
      </marker>
    </defs>
    <g class="edges">
      <path d="M210 139 L320 125" marker-end="url(#product-arrow)"></path>
      <text x="265" y="104" text-anchor="middle">{copy.userToSnapvm}</text>
      <path d="M550 125 L660 125" marker-end="url(#product-arrow)"></path>
      <text x="605" y="104" text-anchor="middle">{copy.snapvmToSprites}</text>
    </g>
    <g class="nodes">
      {
        nodes.map((node) => (
          <g class={`node node-${node.key}`}>
            <rect x={node.x} y={node.y} width={node.width} height={node.height} rx="7"></rect>
            <text class="node-title" x={node.x + node.width / 2} y={node.y + 38} text-anchor="middle">
              {node.title}
            </text>
            {node.items.length > 0 && (
              <text class="node-items" x={node.x + 24} y={node.y + 76}>
                {node.items.map((item, index) => (
                  <tspan x={node.x + 24} dy={index === 0 ? 0 : 25}>
                    {item}
                  </tspan>
                ))}
              </text>
            )}
          </g>
        ))
      }
    </g>
  </svg>
</figure>

<style>
  @layer starlight.components {
    .product-layer-diagram {
      overflow-x: auto;
      margin-block: 1.5rem;
      border: 1px solid var(--sl-color-hairline);
      border-radius: 0.5rem;
      padding: 1rem;
      background:
        linear-gradient(
          color-mix(in srgb, var(--sl-color-bg) 95%, transparent),
          color-mix(in srgb, var(--sl-color-bg) 95%, transparent)
        ),
        linear-gradient(var(--sl-color-hairline) 1px, transparent 1px),
        linear-gradient(90deg, var(--sl-color-hairline) 1px, transparent 1px);
      background-size:
        auto,
        4.5rem 4.5rem,
        4.5rem 4.5rem;
    }

    svg {
      display: block;
      min-inline-size: 44rem;
      inline-size: 100%;
      block-size: auto;
    }

    .edges path {
      fill: none;
      stroke: color-mix(in srgb, var(--sl-color-text) 34%, var(--sl-color-bg));
      stroke-width: 2;
    }

    .edges text {
      fill: var(--sl-color-text-accent);
      font-family: var(--sl-font);
      font-size: 0.78rem;
      font-weight: 600;
    }

    marker path {
      fill: color-mix(in srgb, var(--sl-color-text) 40%, var(--sl-color-bg));
    }

    .node rect {
      fill: color-mix(in srgb, var(--sl-color-bg-nav) 92%, var(--sl-color-white));
      stroke: color-mix(in srgb, var(--sl-color-text) 18%, var(--sl-color-hairline));
      stroke-width: 1.5;
      filter: drop-shadow(0 0.5rem 1rem rgb(0 0 0 / 8%));
    }

    .node text {
      fill: var(--sl-color-text);
      font-family: var(--sl-font);
    }

    .node-title {
      font-size: 1rem;
      font-weight: 650;
    }

    .node-items {
      fill: var(--sl-color-text-accent);
      font-size: 0.84rem;
      font-weight: 500;
    }

    .node-snapvm rect {
      fill: color-mix(in srgb, var(--sl-color-accent-low) 36%, var(--sl-color-bg-nav));
      stroke: color-mix(in srgb, var(--sl-color-accent) 35%, var(--sl-color-hairline));
    }
  }
</style>
