---
const t = (Astro.locals as { t: (key: string) => string }).t;
const pathname = Astro.url.pathname;
const currentLocale = pathname === '/ja' || pathname.startsWith('/ja/') ? 'ja' : 'root';

function rootPathname(): string {
  if (pathname === '/ja') return '/';
  if (pathname.startsWith('/ja/')) return pathname.slice('/ja'.length) || '/';
  return pathname;
}

function localizedPathname(locale: 'root' | 'ja'): string {
  const rootPath = rootPathname();
  if (locale === 'root') return rootPath;
  return rootPath === '/' ? '/ja/' : `/ja${rootPath}`;
}

const currentLabel = currentLocale === 'ja' ? '日本語' : 'English';
const label = `${t('languageSelect.accessibleLabel')}: ${currentLabel}`;
const locales = [
  {
    id: 'root',
    label: 'English',
    lang: 'en',
    path: localizedPathname('root'),
  },
  {
    id: 'ja',
    label: '日本語',
    lang: 'ja',
    path: localizedPathname('ja'),
  },
] as const;
---

<details class="snap-language-select">
  <summary
    class="snap-language-toggle"
    aria-label={`${t('languageSelect.accessibleLabel')}: ${currentLabel}`}
    title={label}
  >
    <svg
      class="icon globe-icon"
      aria-hidden="true"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M3 12h18"></path>
      <path d="M12 3a14 14 0 0 1 0 18"></path>
      <path d="M12 3a14 14 0 0 0 0 18"></path>
    </svg>
    <span class="snap-language-current">{currentLabel}</span>
    <svg
      class="icon chevron-icon"
      aria-hidden="true"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <div class="snap-language-menu" role="menu">
    {
      locales.map((locale) => {
        const isCurrent = locale.id === currentLocale;
        return (
          <a
            class:list={['snap-language-option', { 'is-current': isCurrent }]}
            href={locale.path}
            lang={locale.lang}
            role="menuitem"
            aria-current={isCurrent ? 'page' : undefined}
          >
            <span>{locale.label}</span>
            {isCurrent && (
              <svg
                class="icon check-icon"
                aria-hidden="true"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
            )}
          </a>
        );
      })
    }
  </div>
</details>

<style>
  @layer starlight.components {
    .snap-language-select {
      position: relative;
      display: inline-flex;
    }

    .snap-language-toggle {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      min-width: 5.75rem;
      min-inline-size: 5.75rem;
      block-size: 2.25rem;
      border: 0;
      border-radius: 0.45rem;
      padding-left: 0.6rem;
      padding-right: 0.6rem;
      padding-inline: 0.6rem;
      background: transparent;
      color: var(--sl-color-text-accent);
      box-shadow: none;
      cursor: pointer;
      font: inherit;
      list-style: none;
    }

    .snap-language-toggle:hover,
    .snap-language-toggle:focus-visible {
      background: color-mix(in srgb, var(--sl-color-text) 8%, transparent);
      color: var(--sl-color-text);
    }

    .snap-language-toggle:focus-visible {
      outline: 2px solid var(--sl-color-blue);
      outline-offset: 2px;
    }

    .snap-language-toggle::-webkit-details-marker {
      display: none;
    }

    .icon {
      pointer-events: none;
      flex: 0 0 auto;
    }

    .globe-icon {
      inline-size: 1rem;
      block-size: 1rem;
    }

    .snap-language-current {
      color: var(--sl-color-text);
      font-size: var(--sl-text-sm);
      font-weight: 600;
      line-height: 1;
      white-space: nowrap;
    }

    .chevron-icon {
      inline-size: 0.72rem;
      block-size: 0.72rem;
      transition: transform 120ms ease;
    }

    .snap-language-select[open] .chevron-icon {
      transform: rotate(180deg);
    }

    .snap-language-menu {
      position: absolute;
      inset-block-start: calc(100% + 0.4rem);
      inset-inline-end: 0;
      z-index: calc(var(--sl-z-index-toc, 30) + 1);
      min-inline-size: 9rem;
      padding: 0.25rem;
      border: 1px solid var(--sl-color-hairline);
      border-radius: 0.45rem;
      background: var(--sl-color-bg-nav);
      box-shadow: var(--sl-shadow-md, 0 10px 30px rgba(20, 20, 20, 0.12));
      backdrop-filter: blur(10px);
    }

    .snap-language-option {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      min-block-size: 2rem;
      border-radius: 0.3rem;
      padding-inline: 0.65rem 0.5rem;
      color: var(--sl-color-text);
      font-size: var(--sl-text-sm);
      font-weight: 500;
      line-height: 1;
      text-decoration: none;
      white-space: nowrap;
    }

    .snap-language-option:hover,
    .snap-language-option:focus-visible {
      background: var(--sl-color-accent-low);
      color: var(--sl-color-accent-high);
      outline: none;
    }

    .snap-language-option.is-current {
      color: var(--sl-color-blue-high);
    }

    .check-icon {
      inline-size: 0.85rem;
      block-size: 0.85rem;
    }
  }
</style>
